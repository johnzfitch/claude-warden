          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "tokens_saved"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Tokens Saved"
              },
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rule"
            },
            "properties": [
              {
                "id": "custom.width",
