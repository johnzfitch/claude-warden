              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "tool"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "original_cmd"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Command"
              },
              {
                "id": "custom.width",
                "value": 560
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "format": "auto"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "id": true,
              "tsNs": true,
              "labels": true,
              "Line": true,
              "labelTypes": true,
              "severity_number": true,
              "severity_text": true,
              "detected_level": true,
              "log_file_name": true,
              "session_relative_ts": true,
              "timestamp": true,
              "event_type": true,
              "service_name": true,
              "session_id": true,
              "TraceID": true,
              "Session ID": true,
              "session_id_extracted": true,
              "tool_name": true
            },
            "indexByName": {
              "Time": 0,
              "tool": 1,
              "rule": 2,
              "tokens_saved": 3,
              "original_cmd": 4
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-warden"
          },
          "expr": "{service_name=\"claude-code\", session_id=\"$session_id\"} | json | event_type=\"blocked\"",
          "refId": "A"
