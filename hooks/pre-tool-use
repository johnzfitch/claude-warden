#!/usr/bin/env bash
# Pre-tool-use hook: Token dump prevention, command safety, subagent enforcement
# Consolidated: pre-tool-use + ffmpeg-silent + subagent-guard (3 hooks -> 1)

set -o pipefail

# Source shared library
source "${BASH_SOURCE[0]%/*}/lib/common.sh"

_warden_read_input || exit 0

# === SINGLE JQ CALL ===
TOOL_NAME=$(_warden_parse_tool_name)
TRANSCRIPT_PATH=$(_warden_parse_transcript_path)
SESSION_ID=$(_warden_parse_session_id)
IFS=$'\t' read -r COMMAND < <(_warden_parse_tool_input command)

# Export for shared library functions
export WARDEN_TOOL_NAME="$TOOL_NAME"
export WARDEN_COMMAND="$COMMAND"
export WARDEN_SESSION_ID="$SESSION_ID"

# Record tool start for latency tracking (read by post-tool-use)
_warden_record_tool_start "$TOOL_NAME"

# === MCP TOOL TRACKING ===
# Log MCP tool calls for separate monitoring (server name from mcp__server__tool pattern)
if [[ "$TOOL_NAME" == mcp__* ]]; then
    MCP_SERVER=$(echo "$TOOL_NAME" | cut -d_ -f3)
    MCP_TOOL=$(echo "$TOOL_NAME" | cut -d_ -f4-)
    _TS=$((_WARDEN_NOW_S - _WARDEN_SESSION_START_S))
    printf '{"timestamp":%d,"event_type":"mcp_tool_start","tool":"%s","mcp_server":"%s","mcp_tool":"%s"}\n' \
        "$_TS" "$TOOL_NAME" "$MCP_SERVER" "$MCP_TOOL" \
        >> "$WARDEN_EVENTS_FILE" 2>/dev/null
fi

# === SUBAGENT DETECTION (applies to ALL tools) ===
IS_SUBAGENT=false
AGENT_TYPE=""
AGENT_ID=""

if _warden_is_subagent "$TRANSCRIPT_PATH"; then
    IS_SUBAGENT=true
    AGENT_ID=$(_warden_get_agent_id "$TRANSCRIPT_PATH")
    if [[ -n "$AGENT_ID" ]]; then
        AGENT_TYPE=$(_warden_get_agent_type "$AGENT_ID")
    fi
fi

# === SUBAGENT BUDGET ENFORCEMENT (applies to ALL tools) ===
if [[ "$IS_SUBAGENT" == true && -n "$AGENT_ID" ]]; then
    # Call/byte limits per agent type (Bash 3.2 compatible via indirect expansion)
    CALL_BUDGET=$(_warden_call_limit "$AGENT_TYPE")
    BYTE_BUDGET=$(_warden_byte_limit "$AGENT_TYPE")

    WARN_CALL_AT=$((CALL_BUDGET * 80 / 100))
    WARN_BYTE_AT=$((BYTE_BUDGET * 80 / 100))

    mkdir -p "$WARDEN_SUBAGENT_STATE_DIR"
    CALL_FILE="$WARDEN_SUBAGENT_STATE_DIR/$AGENT_ID.calls"
    BYTE_FILE="$WARDEN_SUBAGENT_STATE_DIR/$AGENT_ID.bytes"

    # Read + increment call count
    CURRENT_CALLS=0
    if [[ -f "$CALL_FILE" ]]; then
        RAW=$(cat "$CALL_FILE" 2>/dev/null || echo "0")
        if [[ "$RAW" == *"|"* ]]; then
            CURRENT_CALLS=$(echo "$RAW" | cut -d'|' -f2)
        else
            CURRENT_CALLS="$RAW"
        fi
        [[ ! "$CURRENT_CALLS" =~ ^[0-9]+$ ]] && CURRENT_CALLS=0
    fi
    NEW_CALLS=$((CURRENT_CALLS + 1))
    printf '%s|%s|%s\n' "$AGENT_ID" "$NEW_CALLS" "$(date +%s)" > "$CALL_FILE"

    # Read cumulative output bytes (written by post-tool-use)
    CURRENT_BYTES=0
    if [[ -f "$BYTE_FILE" ]]; then
        RAW=$(cat "$BYTE_FILE" 2>/dev/null || echo "0")
        if [[ "$RAW" == *"|"* ]]; then
            CURRENT_BYTES=$(echo "$RAW" | cut -d'|' -f1)
        else
            CURRENT_BYTES="$RAW"
        fi
        [[ ! "$CURRENT_BYTES" =~ ^[0-9]+$ ]] && CURRENT_BYTES=0
    fi

    # Enforce call count budget
    if (( NEW_CALLS >= CALL_BUDGET )); then
        _warden_emit_block "budget_calls_exceeded" 2000
        _warden_deny "Budget exceeded: $AGENT_TYPE calls $NEW_CALLS/$CALL_BUDGET. Stop and report findings."
    elif (( NEW_CALLS >= WARN_CALL_AT )); then
        echo "WARNING: Tool call #$NEW_CALLS/$CALL_BUDGET for $AGENT_TYPE agent." >&2
    fi

    # Enforce cumulative output bytes budget
    if (( CURRENT_BYTES >= BYTE_BUDGET )); then
        _warden_emit_block "budget_bytes_exceeded" $((CURRENT_BYTES / 4))
        _warden_deny "Budget exceeded: $AGENT_TYPE output ${CURRENT_BYTES}B/${BYTE_BUDGET}B. Stop and report findings."
    elif (( CURRENT_BYTES >= WARN_BYTE_AT )); then
        echo "WARNING: ${CURRENT_BYTES}B/$((BYTE_BUDGET/1024))KB cumulative output for $AGENT_TYPE agent." >&2
    fi
fi

# === NON-BASH TOOLS: fast path ===
case "$TOOL_NAME" in
    Write)
        CONTENT=$(printf '%s' "$WARDEN_INPUT" | jq -r '.tool_input.content // ""' 2>/dev/null)
        FILE_PATH=$(printf '%s' "$WARDEN_INPUT" | jq -r '.tool_input.file_path // ""' 2>/dev/null)
        (( ${#CONTENT} > WARDEN_WRITE_MAX_BYTES )) && { _warden_emit_block "write_oversize" 25000 "Write ${#CONTENT}B → $FILE_PATH"; _warden_deny "Write >${#CONTENT}B (>$((WARDEN_WRITE_MAX_BYTES/1024))KB)"; }
        # Block writes to Claude settings (hook tampering)
        if [[ "$FILE_PATH" =~ \.claude/(settings|hooks) ]] || [[ "$FILE_PATH" =~ \.claude/settings\.(json|local\.json) ]]; then
            _warden_emit_block "settings_write" 0 "Write → $FILE_PATH"; _warden_deny "Sandbox violation: Write to $FILE_PATH blocked. Claude settings and hook files are protected from model writes."
        fi
        _warden_suppress_ok ;;
    Edit)
        NEW=$(printf '%s' "$WARDEN_INPUT" | jq -r '.tool_input.new_string // ""' 2>/dev/null)
        FILE_PATH=$(printf '%s' "$WARDEN_INPUT" | jq -r '.tool_input.file_path // ""' 2>/dev/null)
        (( ${#NEW} > WARDEN_EDIT_MAX_BYTES )) && { _warden_emit_block "edit_oversize" 12500 "Edit ${#NEW}B → $FILE_PATH"; _warden_deny "Edit >${#NEW}B (>$((WARDEN_EDIT_MAX_BYTES/1024))KB)"; }
        # Block edits to Claude settings (hook tampering)
        if [[ "$FILE_PATH" =~ \.claude/(settings|hooks) ]] || [[ "$FILE_PATH" =~ \.claude/settings\.(json|local\.json) ]]; then
            _warden_emit_block "settings_edit" 0 "Edit → $FILE_PATH"; _warden_deny "Sandbox violation: Edit to $FILE_PATH blocked. Claude settings and hook files are protected from model edits."
        fi
        _warden_suppress_ok ;;
    NotebookEdit)
        NEW_SOURCE=$(printf '%s' "$WARDEN_INPUT" | jq -r '.tool_input.new_source // ""' 2>/dev/null)
        (( ${#NEW_SOURCE} > WARDEN_NOTEBOOK_MAX_BYTES )) && { _warden_emit_block "notebook_oversize" 12500 "NotebookEdit ${#NEW_SOURCE}B"; _warden_deny "NotebookEdit >${#NEW_SOURCE}B (>$((WARDEN_NOTEBOOK_MAX_BYTES/1024))KB)"; }
        _warden_suppress_ok ;;
    Glob)
        read -r PATTERN GLOB_PATH < <(printf '%s' "$WARDEN_INPUT" | jq -r '[.tool_input.pattern // "", .tool_input.path // ""] | @tsv' 2>/dev/null)
        HOME_DIR_RE='^(/home/[^/]+|~|/Users/[^/]+|/root)/?$'
        if [[ "$PATTERN" =~ \*\* ]]; then
            if [[ "$GLOB_PATH" =~ $HOME_DIR_RE ]] || [[ -z "$GLOB_PATH" && "$PWD" =~ $HOME_DIR_RE ]]; then
                _warden_emit_block "glob_home_recursive" 5000 "Glob $PATTERN in $GLOB_PATH"; _warden_deny "Glob ** in home dir; narrow path or use fd"
            fi
            if [[ "$PATTERN" =~ ^(/home/[^/]+|~|/Users/[^/]+|/root)/\*\* ]]; then
                _warden_emit_block "glob_home_recursive" 5000 "Glob $PATTERN"; _warden_deny "Glob ** in home dir; narrow path or use fd"
            fi
        fi
        _warden_suppress_ok ;;
    WebFetch|WebSearch)
        # === SSRF / INTERNAL NETWORK PROTECTION ===
        # Block requests to internal networks, cloud metadata endpoints, and localhost.
        _URL=$(printf '%s' "$WARDEN_INPUT" | jq -r '.tool_input.url // .tool_input.query // ""' 2>/dev/null)
        _URL_LOWER=$(printf '%s' "$_URL" | tr '[:upper:]' '[:lower:]')
        # Cloud metadata endpoints (AWS, GCP, Azure, DigitalOcean, Oracle)
        if [[ "$_URL_LOWER" =~ 169\.254\.169\.254 ]] || \
           [[ "$_URL_LOWER" =~ metadata\.google\.internal ]] || \
           [[ "$_URL_LOWER" =~ 169\.254\.169\.250 ]] || \
           [[ "$_URL_LOWER" =~ 100\.100\.100\.200 ]]; then
            _warden_emit_block "ssrf_metadata" 0 "$TOOL_NAME $_URL"
            _warden_deny "Network boundary violation: $TOOL_NAME tried to reach cloud metadata endpoint ($_URL). This is a protected internal address that exposes instance credentials."
        fi
        # Localhost / loopback
        if [[ "$_URL_LOWER" =~ ^https?://(localhost|127\.[0-9]+\.[0-9]+\.[0-9]+|0\.0\.0\.0|\[::1\]) ]]; then
            _warden_emit_block "ssrf_localhost" 0 "$TOOL_NAME $_URL"
            _warden_deny "Network boundary violation: $TOOL_NAME tried to reach localhost ($_URL). This tool cannot access local services. Run the local request directly in your terminal and share the relevant output, or read specific log files."
        fi
        # Private RFC1918 ranges
        if [[ "$_URL_LOWER" =~ ^https?://(10\.[0-9]+|172\.(1[6-9]|2[0-9]|3[01])\.[0-9]+|192\.168\.[0-9]+)\.[0-9]+ ]]; then
            _warden_emit_block "ssrf_private" 0 "$TOOL_NAME $_URL"
            _warden_deny "Network boundary violation: $TOOL_NAME tried to reach private network ($_URL). Internal network access is not allowed via $TOOL_NAME."
        fi
        # Log the domain for audit
        _warden_emit_event "allowed" 0 0 "web_access"
        _warden_suppress_ok ;;
    Bash) ;;  # Continue to Bash checks below
    *) _warden_suppress_ok ;;
esac

[[ -z "$COMMAND" ]] && _warden_suppress_ok

# ==========================================================================
# BASH TOOL CHECKS (all Bash-specific logic consolidated here)
# ==========================================================================

# === CRITICAL DENY RULES (must enforce even in non-interactive -p mode) ===
# Destructive: rm (root/home/cwd/glob), mkfs, dd, chmod/chown recursive
NORM_CMD=$(echo "$COMMAND" | tr -s '[:space:]' ' ')
case "$NORM_CMD" in
    *"rm -rf /"*|*"rm -fr /"*|*"rm -rf ~"*|*"rm -fr ~"*|\
    *"rm -rf ."*|*"rm -fr ."*|*"rm -rf *"*|*"rm -fr *"*|\
    *"rm --recursive --force"*|*"rm --force --recursive"*|\
    *"rm -rf --no-preserve-root"*|\
    *"mkfs"*|*"dd if="*|*"dd of=/dev/"*|\
    *"> /dev/sd"*|*"> /dev/nvme"*|\
    *"chmod -R 777 /"*|*"chown -R"*|*"chown --recursive"*)
        _warden_emit_block "destructive_cmd" 0; _warden_deny "Blocked destructive command" ;;
esac

# Fork bomb detection (regex for spacing variants)
if [[ "$NORM_CMD" =~ :\(\)[[:space:]]*\{[[:space:]]*:\|:[[:space:]]*\&[[:space:]]*\} ]]; then
    _warden_emit_block "fork_bomb" 0; _warden_deny "Blocked fork bomb"
fi

# RCE pipe detection: curl/wget piped to any interpreter
case "$NORM_CMD" in
    *"curl"*"|"*"bash"*|*"curl"*"|"*"sh"*|*"curl"*"|"*"zsh"*|\
    *"curl"*"|"*"python"*|*"curl"*"|"*"perl"*|*"curl"*"|"*"ruby"*|*"curl"*"|"*"node"*|\
    *"wget"*"|"*"bash"*|*"wget"*"|"*"sh"*|*"wget"*"|"*"zsh"*|\
    *"wget"*"|"*"python"*|*"wget"*"|"*"perl"*|*"wget"*"|"*"ruby"*|*"wget"*"|"*"node"*|\
    *"bash <(curl"*|*"sh <(curl"*|*"zsh <(curl"*|\
    *"bash <(wget"*|*"sh <(wget"*|*"zsh <(wget"*|\
    *"python"*" <(curl"*|*"python"*" <(wget"*)
        _warden_emit_block "rce_pipe" 0; _warden_deny "Blocked remote code execution" ;;
esac

# === ENVIRONMENT VARIABLE DUMP PREVENTION ===
# Block commands that dump the full environment (API keys, tokens, credentials).
# The output would enter conversation context and persist across turns.
# env/printenv as standalone dump commands (not substrings like "environment")
# Allow: printenv VAR, env VAR=val cmd, env | grep (filtered output)
# Block: bare env, bare printenv, env -0 (full dump variants)
_ENV_CMD=""
if [[ "$COMMAND" =~ (^|[;&|])[[:space:]]*(env|printenv)($|[[:space:];|&]) ]]; then
    _ENV_CMD="${BASH_REMATCH[2]}"
fi
if [[ -n "$_ENV_CMD" ]] && \
   [[ ! "$COMMAND" =~ \|[[:space:]]*(grep|awk|sed|head|tail|wc) ]] && \
   [[ ! "$COMMAND" =~ printenv[[:space:]]+[A-Za-z_] ]] && \
   [[ ! "$COMMAND" =~ env[[:space:]]+[A-Za-z_][A-Za-z0-9_]*= ]]; then
    _warden_emit_block "env_dump" 0
    _warden_deny "Environment safety: '${COMMAND:0:60}' dumps all environment variables including API keys and tokens into conversation context. Query specific variables instead: echo \$VAR_NAME, or filter: env | grep PATTERN"
fi
# bare export/set/declare -x (no arguments = full dump)
if [[ "$COMMAND" =~ ^[[:space:]]*(export|set|declare[[:space:]]+-x)[[:space:]]*$ ]]; then
    _warden_emit_block "env_dump" 0
    _warden_deny "Environment safety: '${COMMAND:0:60}' dumps all environment variables. Query specific variables instead: echo \$VAR_NAME"
fi
# /proc/self/environ contains null-separated env (binary dump of all vars)
if [[ "$COMMAND" =~ /proc/(self|[0-9]+)/environ ]]; then
    _warden_emit_block "env_dump_proc" 0
    _warden_deny "Environment safety: '${COMMAND:0:80}' reads raw process environment containing all secrets. Query specific variables instead: echo \$VAR_NAME"
fi

# === DATA EXFILTRATION PREVENTION ===
# Block curl/wget with data upload flags (POST body, file upload, form data)
if [[ "$COMMAND" =~ (^|[;&|[:space:]])curl[[:space:]] ]]; then
    if [[ "$COMMAND" =~ [[:space:]](-d[^[:space:]]*|--data(=|[[:space:]])|--data-binary(=|[[:space:]])|--data-raw(=|[[:space:]])|--data-urlencode(=|[[:space:]])|-F[^[:space:]]*|--form(=|[[:space:]])|--upload-file(=|[[:space:]])|-T[^[:space:]]*) ]]; then
        _warden_emit_block "data_exfil_curl" 0 "curl with data upload"
        _warden_deny "Data upload blocked: '${COMMAND:0:120}' sends data to a remote server. curl with -d/--data/-F/--form/--upload-file/-T is restricted. Ask the user to run this manually if needed."
    fi
fi
if [[ "$COMMAND" =~ (^|[;&|[:space:]])wget[[:space:]] ]] && [[ "$COMMAND" =~ --post-data|--post-file ]]; then
    _warden_emit_block "data_exfil_wget" 0 "wget with POST data"
    _warden_deny "Data upload blocked: '${COMMAND:0:120}' sends data to a remote server. wget with --post-data/--post-file is restricted. Ask the user to run this manually if needed."
fi

# === SSRF VIA BASH (curl/wget to internal networks) ===
if [[ "$COMMAND" =~ (curl|wget)[[:space:]] ]]; then
    _CMD_LOWER=$(printf '%s' "$COMMAND" | tr '[:upper:]' '[:lower:]')
    if [[ "$_CMD_LOWER" =~ 169\.254\.169\.254 ]] || \
       [[ "$_CMD_LOWER" =~ metadata\.google\.internal ]] || \
       [[ "$_CMD_LOWER" =~ 169\.254\.169\.250 ]] || \
       [[ "$_CMD_LOWER" =~ 100\.100\.100\.200 ]]; then
        _warden_emit_block "ssrf_metadata_bash" 0
        _warden_deny "Network boundary violation: '${COMMAND:0:120}' targets a cloud metadata endpoint. These addresses expose instance credentials and are never safe to query from model context."
    fi
    if [[ "$_CMD_LOWER" =~ (curl|wget)[[:space:]]+[^|]*https?://(localhost|127\.[0-9]|0\.0\.0\.0|\[::1\]) ]]; then
        _warden_emit_block "ssrf_localhost_bash" 0
        _warden_deny "Network boundary violation: '${COMMAND:0:120}' targets localhost/loopback. If you need local service data, ask the user to provide it or check specific log files."
    fi
    # Private RFC1918 ranges (10.x, 172.16-31.x, 192.168.x)
    if [[ "$_CMD_LOWER" =~ (curl|wget)[[:space:]]+[^|]*https?://(10\.[0-9]|172\.(1[6-9]|2[0-9]|3[01])\.|192\.168\.) ]]; then
        _warden_emit_block "ssrf_private_bash" 0
        _warden_deny "Network boundary violation: '${COMMAND:0:120}' targets a private network address. Internal network access via curl/wget is not allowed. Ask the user to provide the data or check specific files."
    fi
fi

# === RAW SOCKET / NETWORK SCAN TOOLS ===
if [[ "$COMMAND" =~ (^|[;&|[:space:]])(nc|ncat|netcat|socat)[[:space:]] ]]; then
    _MATCHED_TOOL="${BASH_REMATCH[2]}"
    _warden_emit_block "raw_socket" 0
    _warden_deny "Network safety: '${COMMAND:0:80}' uses raw socket tool $_MATCHED_TOOL. Raw socket connections (nc/ncat/netcat/socat) are not permitted. Use curl for HTTP or ssh for remote access."
fi
if [[ "$COMMAND" =~ (^|[;&|[:space:]])(nmap|masscan|zmap)[[:space:]] ]]; then
    _MATCHED_TOOL="${BASH_REMATCH[2]}"
    _warden_emit_block "network_scan" 0
    _warden_deny "Network safety: '${COMMAND:0:80}' runs network scanner $_MATCHED_TOOL. Port scanning and network enumeration are not permitted from model context."
fi

# === SSH/SCP/RSYNC — log for main agent, deny for subagents ===
if [[ "$COMMAND" =~ (^|[;&|[:space:]])(ssh|scp|rsync)[[:space:]] ]]; then
    _MATCHED_TOOL="${BASH_REMATCH[2]}"
    if [[ "$IS_SUBAGENT" == true ]]; then
        _warden_emit_block "subagent_network" 0
        _warden_deny "Subagent boundary: '${COMMAND:0:80}' uses $_MATCHED_TOOL which requires network access. Subagents cannot use ssh/scp/rsync. Return this task to the main agent."
    fi
    # Main agent: log the network access for audit trail
    _warden_emit_event "allowed" 0 0 "network_ssh"
fi

# === SETTINGS FILE TAMPERING VIA BASH ===
_SETTINGS_RE='\.claude/(settings|hooks)'
_REDIR_RE='>[[:space:]]*\.claude/(settings|hooks)'
if [[ "$COMMAND" =~ $_SETTINGS_RE ]]; then
    # Catch redirects writing into settings/hooks paths, or commands that modify them
    if [[ "$COMMAND" =~ (mv|cp|ln|tee|sed[[:space:]]+-i)[[:space:]] ]] || \
       [[ "$COMMAND" =~ $_REDIR_RE ]]; then
        _warden_emit_block "settings_tamper_bash" 0
        _warden_deny "Sandbox violation: '${COMMAND:0:100}' modifies Claude settings or hook files. These files are protected. Reading is allowed but writes are blocked."
    fi
fi

# === SUBAGENT BASH-SPECIFIC BLOCKS ===
if [[ "$IS_SUBAGENT" == true ]]; then
    [[ "$COMMAND" =~ (^|[[:space:]]|[;&|])[[:space:]]*find[[:space:]] ]] && { _warden_emit_block "subagent_find" 3000; _warden_deny "Use Glob tool instead of find"; }
    [[ "$COMMAND" =~ xargs[[:space:]]+(grep|rg) ]] && { _warden_emit_block "subagent_xargs_grep" 5000; _warden_deny "Use Grep tool instead of xargs grep"; }
    [[ "$COMMAND" =~ (^|[;&]|&&|\|\|)[[:space:]]*grep[[:space:]] ]] && { _warden_emit_block "subagent_grep" 5000; _warden_deny "Use Grep tool or rg instead of grep"; }
    [[ "$COMMAND" =~ ^[[:space:]]*ls[[:space:]].*(-la|-al|-lah|-lha) ]] && { _warden_emit_block "subagent_ls_verbose" 2000; _warden_deny "Use tree -L 2 or Glob tool instead of ls -la"; }
    [[ "$COMMAND" =~ ^[[:space:]]*cat[[:space:]].*\* ]] && { _warden_emit_block "subagent_cat_glob" 10000; _warden_deny "Use Glob then Read for pattern-matched files"; }
    if [[ "$COMMAND" =~ ^[[:space:]]*cat[[:space:]].*[[:space:]] ]] && [[ ! "$COMMAND" =~ \| ]]; then
        # BUG FIX #3: rg || grep consumes stdin on rg failure - use rg only
        ARGS=$(echo "$COMMAND" | sed 's/^[[:space:]]*cat[[:space:]]*//' | tr ' ' '\n' | rg -v '^-' | awk 'END{print NR}')
        (( ARGS > 2 )) && { _warden_emit_block "subagent_cat_multi" 5000; _warden_deny "Use Read tool for multiple files (parallel)"; }
    fi
fi

# === FFMPEG QUIET OVERRIDE ===
if [[ "$COMMAND" =~ (^|[[:space:]|;&])ffmpeg[[:space:]] ]] && [[ ! "$COMMAND" =~ -nostats ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E 's/(^|[[:space:]])ffmpeg[[:space:]]/\1ffmpeg -nostats -loglevel error /')
    _warden_quiet_override "ffmpeg_quiet_override" "$_QUIET_CMD"
fi

# === GH RUN VIEW --LOG-FAILED QUIET OVERRIDE ===
# Base64 cert/sigstore lines in attestation logs can be thousands of chars.
# Strip lines >400 chars before tailing so actual error messages surface.
if [[ "$COMMAND" =~ gh[[:space:]]+run[[:space:]]+view ]] && [[ "$COMMAND" =~ --log-failed ]] && [[ ! "$COMMAND" =~ 'length <' ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E "s/[[:space:]]*2>&1[[:space:]]*\|[[:space:]]*tail[[:space:]]+-[0-9]+//")
    _QUIET_CMD="${_QUIET_CMD} 2>&1 | awk 'length < 400' | tail -25"
    _warden_quiet_override "gh_run_view_log_filter" "$_QUIET_CMD"
fi

# === FORCE OVERRIDE ===
[[ "$COMMAND" =~ '#'[[:space:]]*'FORCE_READ' ]] && _warden_suppress_ok

# === BUILD ARTIFACTS CHECK ===
BUILD_ARTIFACT='(\.vite/build|/dist/[^/]+\.(js|css)|\.min\.(js|css)|bundle\.(js|css))'
IS_BUILD_ARTIFACT=false
[[ "$COMMAND" =~ $BUILD_ARTIFACT ]] && IS_BUILD_ARTIFACT=true

# === QUICK ALLOW: metadata commands ===
[[ "$COMMAND" =~ ^[[:space:]]*(wc|stat|file|du|md5sum|sha256sum|sha1sum|cksum)[[:space:]] ]] && _warden_suppress_ok

# === QUICK ALLOW: piped output (NOT for build artifacts) ===
if [[ "$IS_BUILD_ARTIFACT" == false ]] && [[ "$COMMAND" =~ \|[[:space:]]*(head|tail|wc|grep|awk|sed)[[:space:]] ]]; then
    _warden_suppress_ok
fi

# === GIT LOG (unbounded dumps entire history) ===
if [[ "$COMMAND" =~ ^[[:space:]]*git[[:space:]]+log ]] && [[ ! "$COMMAND" =~ (-n[[:space:]]*[0-9]+|-[0-9]+|--oneline|--format|--pretty|--since|--after|\|[[:space:]]*(head|tail)) ]]; then
    _warden_emit_block "git_log_unbounded" 10000; _warden_deny "git log needs -n, --oneline, or pipe"
fi

# === GIT QUIET OVERRIDE (commit/clone/fetch/pull) ===
# Inject -q via updatedInput so the command runs quietly without blocking.
# Post-tool-use adds a per-command additionalContext reminder so the model learns.
if [[ "$COMMAND" =~ git[[:space:]]+(commit|clone|fetch|pull) ]] && [[ ! "$COMMAND" =~ (-q|--quiet) ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E 's/(git[[:space:]]+(commit|clone|fetch|pull))/\1 -q/')
    _warden_quiet_override "git_quiet_override" "$_QUIET_CMD"
fi

# === VERBOSE COMMAND QUIET OVERRIDES ===
# Inject quiet flags via updatedInput instead of blocking.
# Post-tool-use adds per-command additionalContext reminders.

# npm install/ci
if [[ "$COMMAND" =~ ^npm[[:space:]]+(install|i|ci)([[:space:]]|$) ]] && [[ ! "$COMMAND" =~ (--silent|--quiet|\||'>'|'&') ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E 's/^(npm[[:space:]]+(install|i|ci))/\1 --silent/')
    _warden_quiet_override "npm_quiet_override" "$_QUIET_CMD"
fi
# cargo build
if [[ "$COMMAND" =~ ^cargo[[:space:]]+build ]] && [[ ! "$COMMAND" =~ (-q|--quiet|\||'>'|'&') ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E 's/^(cargo[[:space:]]+build)/\1 -q/')
    _warden_quiet_override "cargo_quiet_override" "$_QUIET_CMD"
fi
# make
if [[ "$COMMAND" =~ ^make([[:space:]]|$) ]] && [[ ! "$COMMAND" =~ (-s|--silent|\||'>'|'&') ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E 's/^make/make -s/')
    _warden_quiet_override "make_quiet_override" "$_QUIET_CMD"
fi
# pip/pip3/python -m pip install/download
if [[ "$COMMAND" =~ (^|python3?[[:space:]]+-m[[:space:]]+)pip3?[[:space:]]+(install|download) ]] && [[ ! "$COMMAND" =~ (-q|--quiet) ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E 's/(pip3?[[:space:]]+(install|download))/\1 -q/')
    _warden_quiet_override "pip_quiet_override" "$_QUIET_CMD"
fi
# curl: only override if verbose (-v) without output redirection
if [[ "$COMMAND" =~ ^curl[[:space:]] ]]; then
    if [[ "$COMMAND" =~ (-v|--verbose) ]] && [[ ! "$COMMAND" =~ (\||>>?|-o|-O|--output|--remote-name) ]]; then
        _warden_emit_block "curl_verbose" 2000; _warden_deny "curl -v needs output redirection or -o; cannot auto-fix"
    fi
fi
# wget
if [[ "$COMMAND" =~ ^wget[[:space:]] ]] && [[ ! "$COMMAND" =~ (-q|--quiet|-O) ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E 's/^wget/wget -q/')
    _warden_quiet_override "wget_quiet_override" "$_QUIET_CMD"
fi
# docker build/pull
if [[ "$COMMAND" =~ ^docker[[:space:]]+(build|pull) ]] && [[ ! "$COMMAND" =~ (-q|--quiet|\|) ]]; then
    _QUIET_CMD=$(printf '%s' "$COMMAND" | sed -E 's/^(docker[[:space:]]+(build|pull))/\1 -q/')
    _warden_quiet_override "docker_quiet_override" "$_QUIET_CMD"
fi

# === BUILD ARTIFACTS (minified files) ===
if [[ "$IS_BUILD_ARTIFACT" == true ]]; then
    if [[ "$COMMAND" =~ grep ]] && [[ ! "$COMMAND" =~ (head[[:space:]]+-c.*\|[[:space:]]*grep|-l[[:space:]]|--files-with-matches|\|[[:space:]]*(wc|head|tail)) ]]; then
        _warden_emit_block "grep_minified" 25000; _warden_deny "grep on minified file; use Grep tool or pipe head -c first"
    fi
    if [[ "$COMMAND" =~ (cat|head|tail)[[:space:]].*$BUILD_ARTIFACT ]] && [[ ! "$COMMAND" =~ (-c[[:space:]]*[0-9]+) ]]; then
        _warden_emit_block "cat_minified" 25000; _warden_deny "Minified file; use head -c 4000"
    fi
fi

# === RECURSIVE GREP (main agent only - subagent already blocked above) ===
if [[ "$IS_SUBAGENT" == false ]]; then
    if [[ "$COMMAND" =~ (^|[[:space:];&|])grep[[:space:]]+(-[a-zA-Z]*[rR][a-zA-Z]*|.*[[:space:]]-[a-zA-Z]*[rR][a-zA-Z]*|.*--recursive) ]] && [[ ! "$COMMAND" =~ (-l[[:space:]]|--files-with-matches) ]]; then
        [[ ! "$COMMAND" =~ \|[[:space:]]*(head|tail|wc) ]] && {
            _warden_emit_block "grep_recursive" 10000; _warden_deny "grep -r scans all - use rg or grep -l"
        }
    fi
fi

# === RECURSIVE FIND ===
for pat in '\.claude' '\.git' 'node_modules'; do
    if [[ "$COMMAND" =~ (^|[[:space:];&|])find[[:space:]].*$pat ]] && [[ ! "$COMMAND" =~ (-maxdepth[[:space:]]+[1-3]|\|[[:space:]]*(head|tail|wc)|-name[[:space:]]) ]]; then
        _warden_emit_block "find_recursive" 5000; _warden_deny "find in $pat needs -maxdepth or pipe"
    fi
done

# === BOUNDED HEAD/TAIL ===
if [[ "$COMMAND" =~ ^[[:space:]]*(head|tail) ]]; then
    if [[ "$COMMAND" =~ -n[[:space:]]*([0-9]+) ]] || [[ "$COMMAND" =~ -([0-9]+) ]] || [[ "$COMMAND" =~ --lines=([0-9]+) ]]; then
        limit="${BASH_REMATCH[1]}"
        (( limit <= 500 )) && _warden_suppress_ok
    fi
fi

# === LARGE FILE CHECK ===
[[ "$COMMAND" =~ -c[[:space:]]*[0-9]+ ]] && _warden_suppress_ok

if [[ "$COMMAND" =~ ^[[:space:]]*(cat|head|tail|less|more|bat|batcat)[[:space:]]+ ]]; then
    REST="${COMMAND#*"${BASH_REMATCH[0]}"}"
    set -f  # disable globbing for word splitting
    for arg in $REST; do
        case "$arg" in '|'|'&&'|';'|'||'|'>'|'>>'|'<'|'&') break ;; esac
        [[ "$arg" =~ ^- ]] && continue
        expanded="${arg/#\~/$HOME}"
        if [[ -f "$expanded" ]]; then
            filetype=$(file -b "$expanded" 2>/dev/null | head -c 50)
            if [[ "$filetype" =~ ^(ELF|PE32|Mach-O|data|image|audio|video|gzip|Zip|PDF|SQLite|compiled) ]]; then
                _warden_emit_block "binary_file" 10000; _warden_deny "$expanded is binary ($filetype). Use file, xxd, or hexdump"
            fi
            size=$(stat -c%s "$expanded" 2>/dev/null || stat -f%z "$expanded" 2>/dev/null || echo 0)
            if (( size > 1048576 )); then
                _warden_emit_block "large_file" $((size/4)); _warden_deny "$expanded is $((size/1024))KB (>1MB). Use head -c 4000"
            fi
        fi
    done
    set +f  # restore globbing
fi

_warden_suppress_ok
